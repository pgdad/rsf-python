# Build artifacts (deploy.sh creates build/function.zip)
build/

# Transient rsf runtime bundle (deploy.sh creates and removes during packaging)
rsf/

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform state (local state for tutorial simplicity)
*.tfstate
*.tfstate.backup

# Generated at deploy time by deploy.sh
terraform/terraform.tfvars.json

# RSF generated source (recreated by rsf generate)
src/generated/

# Python bytecode
__pycache__/
*.pyc
