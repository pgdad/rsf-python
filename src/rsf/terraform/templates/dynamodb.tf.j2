# DO NOT EDIT - Generated by RSF

<% for table in dynamodb_tables %>
resource "aws_dynamodb_table" "<< resource_id >>_<< table.table_name | replace('-', '_') >>" {
  name         = "<< table.table_name >>"
  billing_mode = "<< table.billing_mode >>"
  hash_key     = "<< table.partition_key.name >>"
<% if table.sort_key %>
  range_key    = "<< table.sort_key.name >>"
<% endif %>
<% if table.billing_mode == "PROVISIONED" %>
  read_capacity  = << table.read_capacity >>
  write_capacity = << table.write_capacity >>
<% endif %>

  attribute {
    name = "<< table.partition_key.name >>"
    type = "<< table.partition_key.type >>"
  }
<% if table.sort_key %>

  attribute {
    name = "<< table.sort_key.name >>"
    type = "<< table.sort_key.type >>"
  }
<% endif %>
}

<% endfor %>
