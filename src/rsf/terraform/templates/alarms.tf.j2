# DO NOT EDIT - Generated by RSF

<% set needs_sns_topic = alarms | selectattr('sns_topic_arn', 'none') | list | length > 0 %>
<% if needs_sns_topic %>
resource "aws_sns_topic" "<< resource_id >>_alarm_notifications" {
  name = "${local.function_name}-alarm-notifications"

  tags = {
    ManagedBy = "rsf"
    Workflow  = var.workflow_name
  }
}
<% endif %>

<% for alarm in alarms %>
<% if alarm.type == "error_rate" %>
resource "aws_cloudwatch_metric_alarm" "<< resource_id >>_error_rate_<< loop.index0 >>" {
  alarm_name          = "${local.function_name}-error-rate-<< loop.index0 >>"
  comparison_operator = "GreaterThanOrEqualToThreshold"
  evaluation_periods  = << alarm.evaluation_periods >>
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = << alarm.period >>
  statistic           = "Sum"
  threshold           = << alarm.threshold >>
  alarm_description   = "Error rate alarm for ${local.function_name}"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.<< resource_id >>.function_name
  }

<% if alarm.sns_topic_arn %>
  alarm_actions = ["<< alarm.sns_topic_arn >>"]
<% else %>
  alarm_actions = [aws_sns_topic.<< resource_id >>_alarm_notifications.arn]
<% endif %>

  tags = {
    ManagedBy = "rsf"
    Workflow  = var.workflow_name
  }
}

<% elif alarm.type == "duration" %>
resource "aws_cloudwatch_metric_alarm" "<< resource_id >>_duration_<< loop.index0 >>" {
  alarm_name          = "${local.function_name}-duration-<< loop.index0 >>"
  comparison_operator = "GreaterThanOrEqualToThreshold"
  evaluation_periods  = << alarm.evaluation_periods >>
  metric_name         = "Duration"
  namespace           = "AWS/Lambda"
  period              = << alarm.period >>
  statistic           = "Average"
  threshold           = << alarm.threshold >>
  alarm_description   = "Duration alarm for ${local.function_name}"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.<< resource_id >>.function_name
  }

<% if alarm.sns_topic_arn %>
  alarm_actions = ["<< alarm.sns_topic_arn >>"]
<% else %>
  alarm_actions = [aws_sns_topic.<< resource_id >>_alarm_notifications.arn]
<% endif %>

  tags = {
    ManagedBy = "rsf"
    Workflow  = var.workflow_name
  }
}

<% elif alarm.type == "throttle" %>
resource "aws_cloudwatch_metric_alarm" "<< resource_id >>_throttle_<< loop.index0 >>" {
  alarm_name          = "${local.function_name}-throttle-<< loop.index0 >>"
  comparison_operator = "GreaterThanOrEqualToThreshold"
  evaluation_periods  = << alarm.evaluation_periods >>
  metric_name         = "Throttles"
  namespace           = "AWS/Lambda"
  period              = << alarm.period >>
  statistic           = "Sum"
  threshold           = << alarm.threshold >>
  alarm_description   = "Throttle alarm for ${local.function_name}"
  treat_missing_data  = "notBreaching"

  dimensions = {
    FunctionName = aws_lambda_function.<< resource_id >>.function_name
  }

<% if alarm.sns_topic_arn %>
  alarm_actions = ["<< alarm.sns_topic_arn >>"]
<% else %>
  alarm_actions = [aws_sns_topic.<< resource_id >>_alarm_notifications.arn]
<% endif %>

  tags = {
    ManagedBy = "rsf"
    Workflow  = var.workflow_name
  }
}

<% endif %>
<% endfor %>
